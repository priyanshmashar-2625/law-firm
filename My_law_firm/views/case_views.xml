<?xml version = '1.0' encoding="utf-8"?>

<odoo>
    <data>
        <record id="view_kanban_law_Case" model="ir.ui.view">
            <field name="name">law.case.kanban</field>
            <field name="model">law.case</field>
            <field name="arch" type="xml">
                <kanban>
                    <templates>
                        <t t-name="card">
                            <div>
                                <strong><field name="name"/></strong>
                                <div>Status: <field name="status"/></div>
                                <div>Client: <field name="client_id"/></div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <record id="view_form_law_case" model="ir.ui.view">
            <field name="name">law.case.form</field>
            <field name="model">law.case</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button name="action_start"
                            string="Start Case"
                            type="object"
                            invisible="status != 'draft'"
                            class="btn-primary"/>

                        <button name="action_close"
                            string="Close Case"
                            type="object"
                            invisible="status != 'active'"
                            class="btn-success"/>


                        <field name="status" widget="statusbar" statusbar_visible="draft,active,closed"/>
                    </header>
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="case_number"/>
                            <field name="client_id"/>
                            <field name="opponent_name"/>
                        </group>
                        <group>
                            <field name="case_type"/>
                            <field name="court_name"/>
                            <field name="filing_date"/>
                            <field name="next_hearing_date"/>
                            <field name="status"/>
                            <field name="closure_invoice_id" readonly="1"/>
                        </group>
                        <notebook>
                            <page string="Hearings">
                                <field name="hearing_ids"/>
                            </page>
                            <page string="Documents">
                                <field name="document_ids"/>
                            </page>
                            <page string="Billing">
                                <field name="billing_ids"/>
                            </page>
                            <page string="Description">
                                <field name="description"/>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_list_law_case" model="ir.ui.view">
            <field name="name">law.case.list</field>
            <field name="model">law.case</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="case_number"/>
                    <field name="client_id"/>
                    <field name="case_type"/>
                    <field name="status"/>
                    <field name="next_hearing_date"/>
                </list>
            </field>
        </record>

        <record id="view_search_law_case" model="ir.ui.view">
            <field name="name">law.case.search</field>
            <field name="model">law.case</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                    <field name="case_number"/>
                    <field name="client_id"/>
                    <field name="case_type"/>
                    <filter name="active_cases"
                        string="Active Cases"
                        domain="[('status','=','active')]"/>
                    <filter name="closed_cases"
                        string="Closed Cases"
                        domain="[('status','=','closed')]"/>
                    <filter name="draft_cases"
                        string="Draft Cases"
                        domain="[('status','=','draft')]"/>
                    <filter name="group_by_client"
                        string="Group by Client"
                        context="{'group_by':'client_id'}"/>
                    <filter name="group_by_status"
                        string="Group by Status"
                        context="{'group_by':'status'}"/>
                    <filter name="group_by_case_type"
                        string="Group by Case Type"
                        context="{'group_by':'case_type'}"/>
                </search>
            </field>
        </record>

        <record id="action_law_case" model="ir.actions.act_window">
            <field name="name">Cases</field>
            <field name="res_model">law.case</field>
            <field name="view_mode">kanban,list,form</field>
            <field name="search_view_id" ref="view_search_law_case"/>
        </record>

        <record id="action_report_law_case_closure" model="ir.actions.report">
            <field name="name">Case Closure Report</field>
            <field name="model">law.case</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">My_law_firm.report_law_case_closure_document</field>
            <field name="report_file">My_law_firm.report_law_case_closure_document</field>
            <field name="binding_model_id" ref="model_law_case"/>
            <field name="binding_type">report</field>
        </record>

        <template id="report_law_case_closure_document">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="o">
                    <t t-call="web.external_layout">
                        <div class="page">
                            <h2>Case Closure Report</h2>
                            <p><strong>Case:</strong> <span t-esc="o.name"/></p>
                            <p><strong>Case Number:</strong> <span t-esc="o.case_number or '-'"/></p>
                            <p><strong>Client:</strong> <span t-esc="o.client_id.name or '-'"/></p>
                            <p><strong>Case Type:</strong> <span t-esc="o.case_type or '-'"/></p>
                            <p><strong>Court:</strong> <span t-esc="o.court_name or '-'"/></p>
                            <p><strong>Status:</strong> <span t-esc="o.status"/></p>

                            <t t-set="paid_bills" t-value="o.billing_ids.filtered_domain([('status', '=', 'paid')])"/>
                            <h3>Paid Bills</h3>
                            <table class="table table-sm o_main_table">
                                <thead>
                                    <tr>
                                        <th>Bill Ref</th>
                                        <th>Billing Type</th>
                                        <th>Billing Date</th>
                                        <th>Invoice</th>
                                        <th class="text-end">Amount</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr t-foreach="paid_bills" t-as="bill">
                                        <td><span t-esc="bill.name"/></td>
                                        <td><span t-esc="bill.billing_type or '-'"/></td>
                                        <td><span t-esc="bill.billing_date_and_time or '-'"/></td>
                                        <td><span t-esc="bill.invoice_id.name or '-'"/></td>
                                        <td class="text-end"><span t-esc="bill.amount"/></td>
                                    </tr>
                                </tbody>
                            </table>

                            <t t-set="grand_total" t-value="sum(paid_bills.mapped('amount'))"/>
                            <p><strong>Grand Total (Paid Bills):</strong> <span t-esc="grand_total"/></p>

                            <h3>Closure Invoice</h3>
                            <t t-if="o.closure_invoice_id">
                                <p><strong>Invoice Number:</strong> <span t-esc="o.closure_invoice_id.name or '-'"/></p>
                                <p><strong>Invoice Date:</strong> <span t-esc="o.closure_invoice_id.invoice_date or '-'"/></p>
                                <p><strong>Invoice Status:</strong> <span t-esc="o.closure_invoice_id.state or '-'"/></p>
                                <p><strong>Invoice Grand Total:</strong> <span t-esc="o.closure_invoice_id.amount_total"/></p>
                            </t>
                            <t t-else="">
                                <t t-set="bill_invoices" t-value="paid_bills.mapped('invoice_id')"/>
                                <t t-if="bill_invoices">
                                    <p><strong>Closure Invoice:</strong> Not generated yet.</p>
                                    <p><strong>Paid Bill Invoices:</strong></p>
                                    <ul>
                                        <li t-foreach="bill_invoices" t-as="inv">
                                            <span t-esc="inv.name or '-'"/> |
                                            <span t-esc="inv.invoice_date or '-'"/> |
                                            <span t-esc="inv.state or '-'"/> |
                                            <span t-esc="inv.amount_total"/>
                                        </li>
                                    </ul>
                                    <p><strong>Total of Invoice Amounts:</strong> <span t-esc="sum(bill_invoices.mapped('amount_total'))"/></p>
                                </t>
                                <t t-else="">
                                    <p>No invoice found for paid bills.</p>
                                </t>
                            </t>
                        </div>
                    </t>
                </t>
            </t>
        </template>
    </data>
</odoo>
