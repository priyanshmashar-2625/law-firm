<odoo>
    <record id="view_kanban_law_document" model="ir.ui.view">
        <field name="name">law.document.kanban</field>
        <field name="model">law.document</field>
        <field name="arch" type="xml">
            <kanban>
                <templates>
                    <t t-name="card">
                        <div>
                            <strong><field name="name"/></strong>
                            <div>Type:<field name="client_id"/></div>
                            <div>Case:<field name="case_id"/></div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_form_law_document" model="ir.ui.view">
        <field name="name">law.document.form</field>
        <field name="model">law.document</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="case_id"/>
                        <field name="client_id"/>
                        <field name="document_type"/>
                    </group>

                    <group>
                        <field name="file" filename="filename"/>
                        <field name="upload_date"/>
                    </group>

                    <group>
                        <field name="notes"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_list_law_document" model="ir.ui.view">
        <field name="name">law.document.list</field>
        <field name="model">law.document</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="case_id"/>
                <field name="document_type"/>
                <field name="upload_date"/>
            </list>
        </field>
    </record>

    <record id="action_law_document" model="ir.actions.act_window">
        <field name="name">Documents</field>
        <field name="res_model">law.document</field>
        <field name="view_mode">kanban,list,form</field>
    </record>

</odoo>