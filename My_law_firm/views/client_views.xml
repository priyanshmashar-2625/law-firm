<?xml version = '1.0' encoding="utf-8"?>

<odoo>
    <data>
        <record id="view_kanban_law_client" model="ir.ui.view">
            <field name="name">law.client.kanban</field>
            <field name="model">law.client</field>
            <field name="arch" type="xml">
                <kanban>
                    <templates>
                        <t t-name="card">
                            <div>
                                <strong><field name="name"/></strong>
                                <div><field name="email"/></div>
                                <div><field name="phone"/></div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <record id="view_form_law_client" model="ir.ui.view">
            <field name="name">law.client.form</field>
            <field name="model">law.client</field>
            <field name="arch" type="xml">
            <form>
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="email"/>
                            <field name="phone"/>
                            <field name="client_type"/>
                            <field name="payment_term_id"/>
                        </group>
                        <group>
                            <field name="address"/>
                        </group>
                        <notebook>
                            <page string="Cases">
                                <field name="case_ids"/>
                            </page>
                            <page string="Notes">
                                <field name="notes"/>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_list_law_client" model="ir.ui.view">
            <field name="name">law.client.list</field>
            <field name="model">law.client</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="email"/>
                    <field name="phone"/>
                    <field name="client_type"/>
                    <field name="payment_term_id"/>
                </list>
            </field>
        </record>

        <record id="view_search_law_client" model="ir.ui.view">
            <field name="name">law.client.search</field>
            <field name="model">law.client</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                    <field name="email"/>
                    <field name="phone"/>
                    <filter name="individuals"
                        string="Individuals"
                        domain="[('client_type','=','individual')]"/>
                    <filter name="companies"
                        string="Companies"
                        domain="[('client_type','=','company')]"/>
                    <filter name="group_by_client_type"
                        string="Group by Client Type"
                        context="{'group_by':'client_type'}"/>
                </search>
            </field>
        </record>

        <record id="action_law_client" model="ir.actions.act_window">
            <field name="name">Clients</field>
            <field name="res_model">law.client</field>
            <field name="view_mode">kanban,list,form</field>
            <field name="search_view_id" ref="view_search_law_client"/>
        </record>
    </data>
</odoo>
