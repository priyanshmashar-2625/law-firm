<?xml version="1.0" encoding="utf-8"?>

<odoo>
    <data>
        <record id="view_form_mark_paid_wizard" model="ir.ui.view">
            <field name="name">mark.paid.wizard.form</field>
            <field name="model">mark.paid.wizard</field>
            <field name="arch" type="xml">
                <form string="Confirm Mark Paid">
                    <group>
                        <div class="o_form_label">Are you sure you want to mark this billing as paid?</div>
                        <field name="billing_id" readonly="1"/>
                    </group>
                    <footer>
                        <button name="action_confirm_mark_paid"
                                string="Confirm"
                                type="object"
                                class="btn-primary"/>
                        <button string="Cancel" special="cancel" class="btn-secondary"/>
                    </footer>
                </form>
            </field>
        </record>
    </data>
</odoo>
